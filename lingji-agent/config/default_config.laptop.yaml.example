# 笔记本 Agent 配置示例（复制为 default_config.yaml 并填入密钥）
# cp config/default_config.laptop.yaml.example config/default_config.yaml

llm:
  api_key: ""
  base_url: https://api.deepseek.com
  model: deepseek-chat
  provider: deepseek
network:
  auth_token: ""
  device_id: lingji-laptop
  display_name: 空城记
  aliases:
    - 空城记
    - 笔记本
    - Laptop
  gateway_host: lingji.mygoal.tech
  gateway_port: 443
  incoming_dir: ~/Downloads/LingjiIncoming
  max_reconnect_delay: 60.0
  reconnect_delay: 1.0
security:
  hitl_enabled: true
  hitl_timeout_sec: 300
  sanitizer_force_docker: true
  guardrails_enabled: true
  guardrails_block: true
  max_execution_time: 30
  max_memory_mb: 256
  sandbox_image: python:3.11-slim
memory:
  enabled: true
  db_path: ~/.lingji/memory_db
  episodic_top_k: 3
  semantic_top_k: 2
  tool_output_max_chars: 1000
  decay_enabled: true
  decay_lambda: 0.01
  prune_min_weight: 0.05
  prune_after_days: 30
  summarize_enabled: true
  summarize_min_episodes: 30
  summarize_batch_size: 20
  summarize_min_age_days: 7
  summarize_interval_hours: 24
  summarize_max_output_chars: 2000
  summarize_cold_start_defer: true
observability:
  enabled: true
  otlp_endpoint: http://127.0.0.1:4317
  otlp_insecure: true
  service_name: lingji-agent
  metrics_enabled: true
  metrics_host: 127.0.0.1
  metrics_port: 9091
  trace_log_enabled: true
scheduler:
  # 调度终端（空城记）：对用户负责，委派青铜剑执行
  enabled: true
  scheduler_agent_id: lingji-laptop
  guardian_executor_ids:
    - lingji-pc
