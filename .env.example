# 复制为 .env 后按需填写（docker compose 自动加载）

# Gateway 映射到宿主机的端口（integration_test 默认 18765）
LINGJI_HOST_PORT=18765

# 三端鉴权（Gateway 与 Agent 需一致；空 = 关闭鉴权）
LINGJI_AUTH_TOKEN=

# Agent full profile
LINGJI_DEVICE_ID=lingji-pc
DEEPSEEK_API_KEY=
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com
SANDBOX_IMAGE=python:3.11-slim

# 四期 4.2 observability（WSL Agent 默认连本机栈）
LINGJI_OTLP_PORT=4317
LINGJI_METRICS_PORT=9091
LINGJI_PROMETHEUS_PORT=9090
LINGJI_GRAFANA_PORT=3000
LINGJI_TEMPO_PORT=3200
GRAFANA_ADMIN_PASSWORD=admin
